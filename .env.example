# Production secrets — copy to `.env` and fill in real values before running docker-compose

# Generate with: openssl rand -hex 48
JWT_SECRET=replace-with-a-long-random-string

# First-run admin bootstrap (created if no admin exists yet — change in admin UI after first login)
ADMIN_DEFAULT_EMAIL=admin@carvo.sa
ADMIN_DEFAULT_PASSWORD=ChangeMe123!

# Get a key from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Comma-separated list of allowed origins for CORS
CORS_ORIGINS=https://www.carvo.sa,https://carvo.sa,https://admin.carvo.sa
